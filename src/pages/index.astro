---
import BaseHead from "../components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <main>
      <p>Hello! I'm</p>
      <h1>Ian De Guzman</h1>
      <p>
        A proud father of one and an Industrial Engineer who fell in love with
        software development
      </p>
      <p>
        Finished my degree in <b>Computer Science</b> while being a full-time Full-Stack
        Software Developer and Mobile Developer (React Native)
      </p>
      <nav>
